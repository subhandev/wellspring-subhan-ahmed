meta {
  name: List audit
  type: http
  seq: 42
}

docs {
  Returns `{ auditLogs }` (newest first, max 500). Each row includes `actorEmail`, `actorId`, `action`, `targetType`, `targetId`, optional `metadata`, and `createdAt`.
}

get {
  url: {{baseUrl}}/v1/audit
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}
