meta {
  name: Create program
  type: http
  seq: 21
}

post {
  url: {{baseUrl}}/v1/programs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "Bruno program",
    "description": "Created from Bruno collection"
  }
}

script:post-response {
  const body = typeof res.body === "object" ? res.body : {};
  const id = body.id;
  if (typeof id === "string") {
    bru.setEnvVar("programId", id);
  }
}
