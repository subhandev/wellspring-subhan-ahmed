meta {
  name: List programs
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/v1/programs
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const rows = typeof res.body === "object" && res.body?.programs ? res.body.programs : [];
  const first = Array.isArray(rows) ? rows[0] : undefined;
  if (first?.id) {
    bru.setEnvVar("programId", first.id);
  }
}
