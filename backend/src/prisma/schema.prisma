generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Past-tense dotted identifiers persisted for audit filters (see `appendAuditLog`).
/// Includes auth lifecycle: `auth.logged_out`, `auth.signed_up`, `auth.password_reset`.
enum AuditLogAction {
  auth_logged_out @map("auth.logged_out")
  auth_signed_up @map("auth.signed_up")
  auth_password_reset @map("auth.password_reset")
  program_created @map("program.created")
  program_updated @map("program.updated")
  program_deleted @map("program.deleted")
  session_created @map("session.created")
  session_updated @map("session.updated")
  session_deleted @map("session.deleted")
  session_reordered @map("session.reordered")
  sessions_imported @map("sessions.imported")
  media_presigned @map("media.presigned")
}

enum SessionImportKeyStatus {
  pending
  success
}

/// Stored kind for session media (MIME from upload lives only in client / presign metadata).
enum SessionMediaType {
  AUDIO
  VIDEO
}

/// Tenant (wellness creator). `id` is used as `tenantId` on child rows.
model Creator {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  passwordResetTokenHash   String?
  passwordResetExpiresAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  programs           Program[]
  auditLogsAsActor   AuditLog[]          @relation("AuditLogActor")
  auditLogsAsTenant  AuditLog[]          @relation("AuditLogTenant")
  sessionImportKeys  SessionImportKey[]
}

model Program {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Creator   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([tenantId])
}

/// `tenantId` is denormalized for tenant-scoped queries without joining `Program`.
/// There is no FK from `tenantId` to `Creator`: the value is always set from the
/// owning program’s tenant at write time; repositories scope reads by `tenantId`.
model Session {
  id              String   @id @default(cuid())
  tenantId        String
  programId       String
  title           String
  durationSeconds Int
  position        Int
  instructorName  String
  tags            String[] @default([])
  mediaUrl        String?
  mediaType       SessionMediaType?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  program    Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  importKeys SessionImportKey[]

  @@unique([programId, position])
  @@index([tenantId])
  @@index([programId, position])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String
  action     AuditLogAction
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor  Creator @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: Cascade)
  tenant Creator @relation("AuditLogTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([actorId])
}

/// Idempotent CSV import: unique per tenant + client import + row id.
model SessionImportKey {
  id             String   @id @default(cuid())
  tenantId       String
  clientImportId String
  clientRowId    String
  sessionId      String?
  status         SessionImportKeyStatus @default(success)
  errorMsg       String?
  createdAt      DateTime @default(now())

  tenant  Creator  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, clientImportId, clientRowId])
  @@index([tenantId])
}
