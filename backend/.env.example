# Copy to backend/.env (do not commit .env)
#
# Railway (hosted API): set service Root Directory to `backend`; link DATABASE_URL
# from the Postgres plugin. Required in production: NODE_ENV, JWT_SECRET, CORS_ORIGIN
# (HTTPS admin origins). See README "Deploy backend (Railway)".

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wellspring"

# HS256; min 16 chars — use a long random value in production
JWT_SECRET="change-me-to-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"
JWT_RESET_EXPIRES_IN="15m"
PASSWORD_RESET_DEBUG_LOG="0"

# Optional comma-separated browser origins (localhost allowed in dev when unset)
# CORS_ORIGIN="http://localhost:3000"

# 1 = OpenAPI + /api-docs without auth
ENABLE_API_DOCS="1"

# Optional S3 (presigned uploads; region must match bucket). See README.
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# PRESIGN_EXPIRES_SECONDS=900
# PRESIGN_GET_EXPIRES_SECONDS=3600
# S3_PUBLIC_BASE_URL=
# S3_ENDPOINT=
