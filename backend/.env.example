DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wellspring"
PORT=4000
LOG_LEVEL=info

# Prisma schema: src/prisma/schema.prisma (pnpm db:* scripts pass --schema).

# JWT (required for signup/login and all protected /v1 routes except auth public endpoints)
JWT_SECRET="change-me-to-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"

# OpenAPI/Swagger: set to 0 to disable /openapi.json + /api-docs (default disabled in NODE_ENV=production unless set to 1)
# ENABLE_API_DOCS="1"

# Set to 1 to log raw password reset tokens at debug level (local only; omit in production)
# PASSWORD_RESET_DEBUG_LOG="1"

# S3 presigned PUT uploads (optional)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET=""
# PRESIGN_EXPIRES_SECONDS=900
# S3_ENDPOINT="http://localhost:9000"
# S3_PUBLIC_BASE_URL="https://your-bucket.s3.us-east-1.amazonaws.com"
