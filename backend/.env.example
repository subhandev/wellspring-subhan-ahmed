# Copy to `backend/.env` and adjust. Never commit `.env` (it is gitignored).
# Layout matches backend/.env so diffs against the template stay readable.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
# Required at runtime for any route that touches the DB (auth, programs, etc.).
# Prisma CLI uses `--schema src/prisma/schema.prisma` via package scripts.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/wellspring"

# -----------------------------------------------------------------------------
# JWT — HS256 secret for access tokens and password-reset JWTs.
# Public routes (no Bearer): POST /api/auth/{signup,login,forgot-password,reset-password},
# GET /health, GET /openapi.json + /api-docs/* (when docs enabled).
# Everything else (including GET /api/auth/me) expects Authorization: Bearer.
# -----------------------------------------------------------------------------
# Minimum 16 characters. Generate for production, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me-to-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"
JWT_RESET_EXPIRES_IN="15m"
# `1` = log raw password-reset URL at debug level (local only). Default off.
PASSWORD_RESET_DEBUG_LOG="0"

# -----------------------------------------------------------------------------
# CORS (browser → API on a different origin, e.g. Next.js admin)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed `Origin` values, e.g. `http://localhost:3000`.
# In development/test, localhost and 127.0.0.1 with any port are allowed if unset.
# CORS_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# OpenAPI / Swagger
# -----------------------------------------------------------------------------
# `1` = expose GET /openapi.json and GET /api-docs without auth.
# `0` = always hide docs.
# If unset: docs are on in development/test; off in production unless you set `1`.
ENABLE_API_DOCS="1"

# -----------------------------------------------------------------------------
# S3 presigned uploads (session media) — required to upload audio/video/image
# -----------------------------------------------------------------------------
# Browser PUTs the file directly to S3 using the presigned URL returned by
# POST /v1/uploads/presign. The bucket must allow PUT (and GET for playback)
# from the admin Origin via CORS. See README → "S3 session media (browser uploads)"
# for the bucket policy and CORS configuration.
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"
# S3_BUCKET="wellspring-media"
# Presigned PUT URL lifetime in seconds (60–3600). 300 = 5 minutes.
# PRESIGN_EXPIRES_SECONDS=900
# Aliases (optional, mapped in loadEnv): AWS_S3_BUCKET → S3_BUCKET,
# S3_PRESIGNED_URL_EXPIRES → PRESIGN_EXPIRES_SECONDS.
#
# Optional: override the public GET origin (CloudFront, custom domain, etc.).
# If unset, publicUrl defaults to https://{S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com/{key}.
# S3_PUBLIC_BASE_URL="https://your-bucket.s3.us-east-1.amazonaws.com"
# Optional: S3-compatible endpoint for MinIO/localstack (enables path-style URLs).
# S3_ENDPOINT="http://localhost:9000"
